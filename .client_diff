+use std::sync::atomic::{AtomicU64, Ordering};
 use std::time::Duration;
 use tokio::time::sleep;
 
+#[derive(Template)]
+#[template(
+    source = r#"[SYSTEM]
+Time:{{ time }}
+{% if remaining_secs > 0 %}RemainingTime:{{ remaining_secs }}s
+{% endif %}Runtime:{{ runtime }}s
+[/SYSTEM]"#,
+    ext = "txt"
+)]
+struct SystemHeaderTemplate<'a> {
+    time: &'a str,
+    remaining_secs: u64,
+    runtime: u64,
+}
+
